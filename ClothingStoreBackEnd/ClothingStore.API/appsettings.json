{

    "ConnectionStrings": {
        "DefaultConnection": "Server=.;Database=ClothingStoreDB;User Id=sa;Password=sa123456;TrustServerCertificate=True;"
    },

    "Jwt": {
        "SecretKey": "MyKey123456789009876543234567890",
        "Issuer": "AgriculturalApp",
        "Audience": "AgriculturalUsers",
        "AccessTokenMinutes": 60,
        "RefreshTokenDays": 7

    },
    
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Information"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/log-.txt",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 30,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Enrich": [
            "FromLogContext"
        ]
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
